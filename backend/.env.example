# ─── Cấu hình Backend API ────────────────────────────────────

# Server
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://minh4bys2_db_user:<password>@photobooth-cluster.5soulnv.mongodb.net/photobooth?retryWrites=true&w=majority&appName=photobooth-cluster

# Cloudinary (lấy từ Dashboard → Settings → API Keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Danh sách booth hợp lệ (JSON)
# Mỗi booth có id và api_key riêng
BOOTHS=[{"id":"booth-01","apiKey":"booth-secret-key-01"},{"id":"booth-02","apiKey":"booth-secret-key-02"}]

# Session hết hạn sau bao nhiêu ngày
SESSION_EXPIRY_DAYS=7

# URL frontend (dùng cho CORS)
FRONTEND_URL=https://yourdomain.com
