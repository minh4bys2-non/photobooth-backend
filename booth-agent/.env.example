# ─── Cấu hình Booth Agent ────────────────────────────────────
# API Backend
API_URL=https://api.yourdomain.com/api/v1
API_KEY=booth-secret-key
BOOTH_ID=booth-01

# URL giao diện frontend cho session (dùng để tạo QR code)
SESSION_FRONTEND_BASE=https://yourdomain.com/s

# Thư mục theo dõi file ảnh / video mới từ dslrBooth
WATCH_DIR=C:/dslrBooth/Output

# Thư mục lưu trữ nội bộ
QR_OUTPUT_DIR=./qrcodes
QUEUE_DIR=./queue
LOG_DIR=./logs

# Chu kỳ thử lại upload thất bại (mili giây)
RETRY_INTERVAL_MS=30000

# Thời gian chờ file ổn định kích thước trước khi upload (mili giây)
FILE_STABLE_MS=2000

# Cửa sổ thời gian nhóm file vào cùng 1 session (mili giây)
# Các file đến trong khoảng thời gian này sau file cuối sẽ dùng chung sessionId
SESSION_WINDOW_MS=10000
